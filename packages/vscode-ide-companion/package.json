{
  "name": "param-code-vscode-ide-companion",
  "displayName": "param Code Companion",
  "description": "Enable param Code with direct access to your VS Code workspace.",
  "version": "0.14.0",
  "publisher": "paramlm",
  "icon": "assets/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/paramLM/param-code.git",
    "directory": "packages/vscode-ide-companion"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "license": "LICENSE",
  "preview": true,
  "categories": [
    "AI"
  ],
  "keywords": [
    "param-code",
    "param code",
    "param",
    "param code",
    "cli",
    "ide integration",
    "ide companion"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onView:param-code.chatView.sidebar",
    "onView:param-code.chatView.secondary",
    "onCommand:param-code.openChat",
    "onCommand:param-code.focusChat",
    "onCommand:param-code.newConversation",
    "onCommand:param-code.showLogs"
  ],
  "contributes": {
    "jsonValidation": [
      {
        "fileMatch": "**/.param/settings.json",
        "url": "./schemas/settings.schema.json"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "param-code-sidebar",
          "title": "param Code",
          "icon": "assets/sidebar-icon.svg",
          "when": "!param-code:supportsSecondarySidebar"
        }
      ],
      "secondarySidebar": [
        {
          "id": "param-code-secondary",
          "title": "param Code",
          "icon": "assets/sidebar-icon.svg",
          "when": "param-code:supportsSecondarySidebar"
        }
      ]
    },
    "views": {
      "param-code-sidebar": [
        {
          "type": "webview",
          "id": "param-code.chatView.sidebar",
          "name": "param Code",
          "icon": "assets/sidebar-icon.svg",
          "when": "!param-code:supportsSecondarySidebar"
        }
      ],
      "param-code-secondary": [
        {
          "type": "webview",
          "id": "param-code.chatView.secondary",
          "name": "param Code",
          "icon": "assets/sidebar-icon.svg",
          "when": "param-code:supportsSecondarySidebar"
        }
      ]
    },
    "languages": [
      {
        "id": "param-diff-editable"
      }
    ],
    "commands": [
      {
        "command": "param.diff.accept",
        "title": "param Code: Accept Current Diff",
        "icon": "$(check)"
      },
      {
        "command": "param.diff.cancel",
        "title": "param Code: Close Diff Editor",
        "icon": "$(close)"
      },
      {
        "command": "param-code.runparamCode",
        "title": "param Code: Run"
      },
      {
        "command": "param-code.showNotices",
        "title": "param Code: View Third-Party Notices"
      },
      {
        "command": "param-code.openChat",
        "title": "param Code: Open",
        "icon": "./assets/icon.png"
      },
      {
        "command": "param-code.login",
        "title": "param Code: Login"
      },
      {
        "command": "param-code.focusChat",
        "title": "param Code: Focus Chat View"
      },
      {
        "command": "param-code.newConversation",
        "title": "param Code: New Conversation"
      },
      {
        "command": "param-code.showLogs",
        "title": "param Code: Show Logs"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "param.diff.accept",
          "when": "param.diff.isVisible"
        },
        {
          "command": "param.diff.cancel",
          "when": "param.diff.isVisible"
        },
        {
          "command": "param-code.login",
          "when": "false"
        }
      ],
      "editor/title": [
        {
          "command": "param.diff.accept",
          "when": "param.diff.isVisible",
          "group": "navigation"
        },
        {
          "command": "param.diff.cancel",
          "when": "param.diff.isVisible",
          "group": "navigation"
        },
        {
          "command": "param-code.openChat",
          "group": "navigation"
        }
      ]
    },
    "keybindings": [
      {
        "command": "param.diff.accept",
        "key": "ctrl+s",
        "when": "param.diff.isVisible"
      },
      {
        "command": "param.diff.accept",
        "key": "cmd+s",
        "when": "param.diff.isVisible"
      },
      {
        "command": "param-code.focusChat",
        "key": "ctrl+shift+l",
        "mac": "cmd+shift+l"
      }
    ]
  },
  "main": "./dist/extension.cjs",
  "type": "module",
  "scripts": {
    "prepackage": "node ./scripts/prepackage.js",
    "build": "npm run build:dev",
    "build:dev": "npm run check-types && npm run lint && node esbuild.js",
    "build:prod": "node esbuild.js --production",
    "generate:notices": "node ./scripts/generate-notices.js",
    "prepare": "npm run generate:notices",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "watch": "npm-run-all2 -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "vsce package --no-dependencies",
    "test": "vitest run",
    "test:ci": "vitest run --coverage",
    "validate:notices": "node ./scripts/validate-notices.js"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "20.x",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "@types/semver": "^7.7.1",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^8.31.1",
    "@typescript-eslint/parser": "^8.31.1",
    "@vscode/vsce": "^3.6.0",
    "autoprefixer": "^10.4.22",
    "esbuild": "^0.25.3",
    "eslint": "^9.25.1",
    "eslint-plugin-react-hooks": "^5.2.0",
    "npm-run-all2": "^8.0.2",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.18",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.14.1",
    "@param-code/webui": "*",
    "@modelcontextprotocol/sdk": "^1.25.1",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "markdown-it": "^14.1.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "semver": "^7.7.2",
    "zod": "^3.25.76"
  }
}
